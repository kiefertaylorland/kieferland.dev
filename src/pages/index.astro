---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { readingTime } from '../lib/readingTime';

const posts = (await getCollection('writing', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout>
	<section class="hero">
		<p class="eyebrow">AI Quality Engineering</p>
		<h1 class="page-title">Kiefer Land</h1>
		<p class="hero-lede">
			As agents write more code, the bottleneck becomes <span class="hero-accent">trust</span>.
			Notes on making AI-built software verifiable.
		</p>
	</section>

	<section class="writing-section">
		<div class="writing-list">
			{
				posts.length > 0 ? (
					posts.map((post) => (
						<a href={`/writing/${post.id}/`} class="writing-row">
							<span class="writing-row-top">
								<span class="writing-date eyebrow">
									<FormattedDate date={post.data.date} />
								</span>
							</span>
							<span class="writing-title">{post.data.title}</span>
							<span class="writing-excerpt">{post.data.description}</span>
							<span class="writing-read">{readingTime(post.body ?? '')} min</span>
						</a>
					))
				) : (
					<p class="writing-empty">Nothing published yet — check back soon.</p>
				)
			}
		</div>
	</section>
</BaseLayout>
