---
import "../styles/global.css";
import { SiteHeader } from "../components/SiteHeader.jsx";
import { IconGitHub } from "../lib/ds/icons.jsx";

const { title = "Kiefer Land — Verification layer" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div style="min-height: 100vh; background: var(--color-bg); color: var(--color-text); font-family: var(--font-sans);">
			<SiteHeader client:load currentPath={currentPath} />
			<main style="max-width: var(--content-width-wide); margin: 0 auto; padding: 0 var(--space-6);">
				<slot />
			</main>
			<footer style="border-top: 1px solid var(--color-border); margin-top: var(--space-16);">
				<div style="max-width: var(--content-width-wide); margin: 0 auto; padding: var(--space-8) var(--space-6); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--space-4);">
					<span style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-text-faint);">
						検証 · evidence over trust · © 2026 Kiefer Land
					</span>
					<div style="display: flex; gap: var(--space-4); color: var(--color-text-muted);">
						<a href="https://github.com/kiefertaylorland" style="color: inherit; display: inline-flex;" aria-label="GitHub">
							<IconGitHub size={18} />
						</a>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>
